# Stable Hy3 profile for three A100 80 GB cards.
#
# This keeps the server-side cap at 262K tokens while using one slot for the
# interactive Omnius workload. Lower per-request context can still be selected
# by the client without multiplying the server KV cache across eight slots.

LLAMA_SERVER_BIN=${LLAMA_SERVER_BIN:-/home/roko/Documents/Projects/Adjacent/llama.cpp/build/bin/llama-server}
MODEL_PATH=${MODEL_PATH:-/srv/hy3/hy3-1M-Q2_K.gguf}
HOST=${HOST:-127.0.0.1}
PORT=${PORT:-11453}

# CUDA_VISIBLE_DEVICES contains physical GPU ids. llama.cpp device names are
# remapped logical ids after CUDA applies this visibility list.
CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-0,1,2}
CUDA_DEVICE_ORDER=${CUDA_DEVICE_ORDER:-PCI_BUS_ID}
NVIDIA_VISIBLE_DEVICES=${NVIDIA_VISIBLE_DEVICES:-0,1,2}
GPU_DEVICES=${GPU_DEVICES:-CUDA0,CUDA1,CUDA2}
REQUIRE_GPU_COUNT=${REQUIRE_GPU_COUNT:-3}

# Layer split is the stable Hy3/MoE mode on this host. Use 1,1,1 so all three
# cards are assigned equal weight share; tensor/row mode remains opt-in.
SPLIT_MODE=${SPLIT_MODE:-layer}
TENSOR_SPLIT=${TENSOR_SPLIT:-1,1,1}
N_GPU_LAYERS=${N_GPU_LAYERS:-all}
MAIN_GPU=${MAIN_GPU:-0}

# Long-context server cap. Set CTX_SIZE lower for a throughput benchmark, but
# do not combine a large cap with PARALLEL > 1 on this 111 GB Q2_K artifact.
CTX_SIZE=${CTX_SIZE:-262000}
PARALLEL=${PARALLEL:-1}
CONT_BATCHING=${CONT_BATCHING:-0}

# A100 prompt-processing defaults. Reduce BATCH_SIZE if a larger model or
# another workload is occupying VRAM.
THREADS=${THREADS:-32}
THREADS_BATCH=${THREADS_BATCH:-32}
BATCH_SIZE=${BATCH_SIZE:-2048}
UBATCH_SIZE=${UBATCH_SIZE:-512}
POLL_BATCH=${POLL_BATCH:-0}

# CUDA attention and cache behavior.
FLASH_ATTN=${FLASH_ATTN:-on}
CACHE_TYPE_K=${CACHE_TYPE_K:-q8_0}
CACHE_TYPE_V=${CACHE_TYPE_V:-q8_0}
KV_OFFLOAD=${KV_OFFLOAD:-1}
FIT=${FIT:-off}
CPU_MOE=${CPU_MOE:-0}
N_CPU_MOE=${N_CPU_MOE:-0}

# Keep observability and deterministic context behavior on in the service.
PERF=${PERF:-1}
METRICS=${METRICS:-1}
WARMUP=${WARMUP:-1}
NO_CONTEXT_SHIFT=${NO_CONTEXT_SHIFT:-1}
JINJA=${JINJA:-1}
CHAT_TEMPLATE_FILE=${CHAT_TEMPLATE_FILE:-}
LOG_VERBOSITY=${LOG_VERBOSITY:-2}
LOG_FILE=${LOG_FILE:-/home/roko/.config/hy3/hy3-llama-live.log}

# Hy3 MTP is enabled only for an MTP GGUF. Leave this as none for the
# currently installed hy3-1M-Q2_K.gguf.
SPEC_TYPE=${SPEC_TYPE:-none}
SPEC_DRAFT_N_MAX=${SPEC_DRAFT_N_MAX:-3}
SPEC_DRAFT_P_MIN=${SPEC_DRAFT_P_MIN:-0.75}
